# Production backend
NODE_ENV=production
HOST=127.0.0.1
PORT=8787
DB_PATH=/opt/airline-operations-center/data/muc.sqlite
UPLOAD_DIR=/opt/airline-operations-center/uploads
COOKIE_SECURE=false

# Optional PostgreSQL mode
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require

# Optional cross-origin frontend mode
# CORS_ORIGIN=https://your-frontend-domain.example.com

# Enable after HTTPS is configured on the public domain
# COOKIE_SECURE=true
